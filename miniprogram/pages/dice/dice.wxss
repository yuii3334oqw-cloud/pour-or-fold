.dice-full{ display:flex;flex-direction:column;height:100vh;padding:16rpx 24rpx 28rpx;box-sizing:border-box; }
.n-pick{ display:flex;justify-content:center;gap:16rpx;margin-bottom:8rpx; }
.n-opt{ width:62rpx;height:62rpx;line-height:56rpx;text-align:center;border:5rpx solid #000;border-radius:8rpx;background:#20161a;color:var(--text);font-weight:700;font-size:30rpx;box-shadow:3rpx 3rpx 0 rgba(0,0,0,.5); }
.n-opt.on{ color:#2a1c06;background:var(--gold); }
.cv{ flex:1;width:100%;display:block; }
.tap-tip{ text-align:center;color:var(--muted);font-size:26rpx;margin:6rpx 0 2rpx; }
.rollbtn{ margin-top:12rpx; }
