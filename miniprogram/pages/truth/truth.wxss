/* 真心话大冒险 */
.td-wrap { text-align: center; padding-bottom: 60rpx; }
.td-hero { padding: 40rpx 10rpx 10rpx; }
.td-title { font-size: 44rpx; font-weight: 800; color: var(--orange); letter-spacing: .06em; }
.td-sub { font-size: 22rpx; color: var(--muted); margin-top: 10rpx; }
.td-count {
  display: inline-block; margin: 20rpx 0; font-size: 22rpx; color: var(--gold-soft);
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(255,255,255,.1);
  border-radius: 30rpx; padding: 8rpx 26rpx;
}
.td-card {
  background: linear-gradient(160deg, #1a212c, #11161e);
  border: 4rpx solid rgba(0,0,0,.55); border-radius: 14rpx;
  padding: 50rpx 30rpx; margin-top: 14rpx; min-height: 200rpx;
  box-shadow: 0 6rpx 0 rgba(0,0,0,.45);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.td-kind { font-size: 34rpx; font-weight: 800; letter-spacing: .1em; margin-bottom: 20rpx; }
.td-kind.truth { color: #5fa6e0; }
.td-kind.dare { color: var(--orange); }
.td-text { font-size: 32rpx; line-height: 1.8; color: var(--text); }
.td-pick { font-size: 30rpx; color: var(--gold-soft); line-height: 1.8; }
.td-btns { display: flex; gap: 16rpx; margin-top: 20rpx; }
.td-btns .pbtn { flex: 1; }
.td-truth { background: #16283a; border-color: #2b4a66; color: #9fc8e8; }
.td-hint { font-size: 22rpx; color: var(--muted); margin-top: 16rpx; }
