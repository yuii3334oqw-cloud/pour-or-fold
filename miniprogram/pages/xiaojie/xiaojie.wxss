.xj-wrap { text-align: center; padding-bottom: 60rpx; }
.xj-top {
  display: inline-block; font-size: 23rpx; color: var(--gold-soft); font-weight: 700;
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(255,255,255,.1);
  border-radius: 30rpx; padding: 10rpx 28rpx; margin: 14rpx 0;
}
.xj-center { display: flex; justify-content: center; margin: 26rpx 0; }
.xj-rule {
  background: linear-gradient(160deg, #1a212c, #11161e);
  border: 4rpx solid rgba(0,0,0,.55); border-radius: 14rpx;
  padding: 26rpx 28rpx; margin-top: 14rpx; text-align: center;
  box-shadow: 0 6rpx 0 rgba(0,0,0,.5);
}
.xj-tag { font-size: 38rpx; color: var(--orange); font-weight: 800; }
.xj-desc { font-size: 27rpx; color: var(--text); line-height: 1.75; margin-top: 12rpx; }
.xj-sub { font-size: 22rpx; color: var(--muted); margin-top: 8rpx; }
.xj-big { font-size: 60rpx; font-weight: 800; color: var(--blood); margin: 26rpx 0 8rpx; }
.xj-row { display: flex; gap: 14rpx; }
.xj-row .pbtn { flex: 1; }
.pbtn.rps { font-size: 56rpx; padding: 34rpx 0; }
.xj-li {
  display: flex; gap: 22rpx; text-align: left;
  background: rgba(255,255,255,.04); border: 2rpx solid rgba(255,255,255,.1);
  border-radius: 10rpx; padding: 16rpx 22rpx; margin-top: 12rpx;
}
.xj-k { color: var(--orange); font-weight: 800; min-width: 60rpx; font-size: 30rpx; }
.xj-v { font-size: 24rpx; color: var(--muted); line-height: 1.5; flex: 1; }
