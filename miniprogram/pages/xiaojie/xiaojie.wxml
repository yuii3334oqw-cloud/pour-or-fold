<import src="/tpl/cards.wxml"/>
<view class="wrap xj-wrap">

  <!-- 设置 -->
  <block wx:if="{{view === 'setup'}}">
    <view class="sec-title">人数(3–12)</view>
    <view class="panel">
      <view class="count-row">
        <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onMinus">−</view>
        <view class="num">{{n}}</view>
        <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onPlus">+</view>
      </view>
      <view class="sec-title">玩家昵称(按座位顺序)</view>
      <view class="name-row" wx:for="{{nameList}}" wx:key="index">
        <view class="seat-num">{{index + 1}}</view>
        <input class="name-ipt" value="{{item}}" maxlength="8" data-i="{{index}}" bindinput="onName"/>
      </view>
    </view>
    <view class="sec-title">玩法</view>
    <view class="panel rules">
      <view class="rule-line">· 围一圈坐,轮流抽牌,按牌面执行整蛊规则。</view>
      <view class="rule-line">· 上家/下家按座位昵称自动判定;K 定酒链式累计。</view>
      <view class="rule-line">· 抽完自动重新洗牌,玩到尽兴为止。</view>
    </view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onStart">开 始 抽 牌</view>
    <view class="foot">请理性饮酒 · 切勿酒驾</view>
  </block>

  <!-- 规则总览 -->
  <block wx:elif="{{view === 'rules'}}">
    <view class="sec-title">小姐牌 · 规则总览</view>
    <view class="xj-li" wx:for="{{refList}}" wx:key="index">
      <view class="xj-k">{{item.k}}</view>
      <view class="xj-v">{{item.v}}</view>
    </view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onRulesBack">返回牌桌</view>
  </block>

  <!-- 抽牌 -->
  <block wx:elif="{{view === 'draw'}}">
    <view class="xj-top">{{topStr}}</view>
    <view class="xj-center">
      <template is="pback" data="{{size: 'sz-lg'}}"/>
    </view>
    <view class="sc-prompt">轮到 <text class="hl">{{vm.me}}</text> 抽牌 · 请把手机递给 TA</view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onDraw">抽 牌</view>
    <view class="xj-row">
      <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onPiao">出尿牌</view>
      <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onRules">规则</view>
      <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onBackSetup">结束</view>
    </view>
  </block>

  <!-- 翻牌结果 -->
  <block wx:elif="{{view === 'reveal'}}">
    <view class="xj-top">{{topStr}}</view>
    <view class="xj-center">
      <template is="pcard" data="{{rs: card.rs, sc: card.sc, red: card.red, size: 'sz-lg'}}"/>
    </view>
    <view class="xj-rule">
      <view class="xj-tag">{{info.tag}}</view>
      <view class="xj-desc">{{info.desc}}</view>
      <block wx:if="{{isK}}">
        <view class="count-row" style="margin-top:20rpx">
          <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onKM">−</view>
          <view class="num" style="font-size:64rpx">{{kPickStr}}</view>
          <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onKP">+</view>
        </view>
        <view class="xj-sub">指定「下一个抽到 K 的人」喝几杯</view>
      </block>
    </view>
    <block wx:if="{{isK}}">
      <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onKConfirm">指定并继续 →</view>
    </block>
    <block wx:else>
      <view class="pbtn gold big" wx:if="{{vm.canDS}}" hover-class="pbtn-press" bindtap="onDS">点杀 · 指定一人</view>
      <view class="pbtn gold big" wx:if="{{vm.canRPS}}" hover-class="pbtn-press" bindtap="onRPS">{{vm.rpsLabel}}</view>
      <view class="pbtn {{(vm.canDS || vm.canRPS) ? 'ghost' : 'gold'}} big" hover-class="pbtn-press" bindtap="onNextPlayer">下 一 位 →</view>
    </block>
  </block>

  <!-- 点杀:选人 -->
  <block wx:elif="{{view === 'dsPick'}}">
    <view class="xj-top">{{topStr}}</view>
    <view class="xj-tag" style="margin-top:24rpx">点杀</view>
    <view class="sc-prompt"><text class="hl">{{vm.me}}</text> 指定一个倒霉蛋</view>
    <view class="pbtn" wx:for="{{vm.list}}" wx:key="i" hover-class="pbtn-press" data-i="{{item.i}}" bindtap="onDSPick">{{item.name}}</view>
    <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onDSRand">随机抽一个</view>
    <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onCancelReveal">取消</view>
  </block>

  <!-- 点杀:定杯数 -->
  <block wx:elif="{{view === 'dsCups'}}">
    <view class="xj-big">✕ {{vm.victim}}</view>
    <view class="xj-rule">
      <view class="xj-desc">{{vm.me}} 判 {{vm.victim}} 喝几杯:</view>
      <view class="count-row" style="margin-top:20rpx">
        <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onDSM">−</view>
        <view class="num" style="font-size:64rpx">{{dsCupsStr}}</view>
        <view class="pbtn stepper" hover-class="pbtn-press" bindtap="onDSP">+</view>
      </view>
    </view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onDSConfirm">就 这 么 定!</view>
  </block>

  <!-- 点杀:结果 -->
  <block wx:elif="{{view === 'dsDone'}}">
    <view class="xj-big">✕ {{vm.victim}}</view>
    <view class="xj-rule"><view class="xj-desc">被点杀!{{vm.victim}} 喝 {{vm.cups}} 杯</view></view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onNextPlayer">下 一 位 →</view>
  </block>

  <!-- 猜拳:选对手 -->
  <block wx:elif="{{view === 'rpsPick'}}">
    <view class="xj-top">{{topStr}}</view>
    <view class="xj-tag" style="margin-top:24rpx">猜拳决斗(输喝 {{vm.stake}} 杯)</view>
    <view class="sc-prompt"><text class="hl">{{vm.me}}</text> 选择对手</view>
    <view class="pbtn" wx:for="{{vm.list}}" wx:key="i" hover-class="pbtn-press" data-i="{{item.i}}" bindtap="onRPSOpp">{{item.name}}</view>
    <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onCancelReveal">取消</view>
  </block>

  <!-- 猜拳:出拳 -->
  <block wx:elif="{{view === 'rpsA' || view === 'rpsB'}}">
    <view class="sc-prompt">把手机交给 <text class="hl">{{vm.who}}</text></view>
    <view class="sc-hint" style="color:#9aa3b0;font-size:24rpx;margin-bottom:20rpx">秘密出拳(别让对方看到)</view>
    <view class="xj-row">
      <view class="pbtn rps" hover-class="pbtn-press" data-c="0" bindtap="onRPSPick">石头</view>
      <view class="pbtn rps" hover-class="pbtn-press" data-c="1" bindtap="onRPSPick">布</view>
      <view class="pbtn rps" hover-class="pbtn-press" data-c="2" bindtap="onRPSPick">剪刀</view>
    </view>
  </block>

  <!-- 猜拳:结果 -->
  <block wx:elif="{{view === 'rpsResult'}}">
    <view class="sc-prompt" style="font-size:36rpx">{{vm.me}} {{vm.ea}}  VS  {{vm.eb}} {{vm.opp}}</view>
    <view class="xj-big" wx:if="{{vm.tie}}" style="color:#d97757">平 局!</view>
    <block wx:else>
      <view class="xj-big">{{vm.loser}} 输</view>
      <view class="xj-rule"><view class="xj-desc">{{vm.loser}} 喝 {{vm.stake}} 杯</view></view>
    </block>
    <view class="xj-row">
      <view class="pbtn {{vm.tie ? 'gold' : 'ghost'}}" hover-class="pbtn-press" bindtap="onRPSReplay">{{vm.tie ? '再 出 一 次' : '再来一局'}}</view>
      <view class="pbtn gold" hover-class="pbtn-press" bindtap="onNextPlayer">完成 · 下一位 →</view>
    </view>
  </block>

  <!-- 尿牌 -->
  <block wx:elif="{{view === 'piao'}}">
    <view class="xj-top">{{topStr}}</view>
    <view class="xj-tag" style="margin-top:24rpx">打出尿牌</view>
    <view class="xj-rule">
      <view class="xj-desc">打出一张「尿牌」= 准许本人去撒尿,此牌用掉作废。没有尿牌的人,中途不许离桌上厕所!</view>
    </view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onPiaoGo">出 牌 · 去 撒 尿!</view>
    <view class="pbtn ghost" hover-class="pbtn-press" bindtap="onCancel">取消</view>
  </block>
  <block wx:elif="{{view === 'piaoDone'}}">
    <view class="xj-big" style="color:#5ad17a">放 行!</view>
    <view class="xj-rule"><view class="xj-desc">尿牌已用掉,尽情去吧~ 没尿牌的继续椋着</view></view>
    <view class="pbtn gold big" hover-class="pbtn-press" bindtap="onCancel">返回</view>
  </block>
</view>
